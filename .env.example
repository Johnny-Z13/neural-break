# Server-only Neon Postgres connection string. Never expose this as a VITE_ variable.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Optional comma-separated origins for a separate web frontend.
# Same-origin Vercel requests work without this.
ALLOWED_SCORE_ORIGINS=

# Optional extra secret used to HMAC rate-limit identifiers.
# DATABASE_URL is used as the server-only fallback salt.
RATE_LIMIT_SALT=
